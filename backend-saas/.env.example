# Database
DATABASE_URL="postgresql://pulpax_user:PulpaxSecurePass2026@localhost:5433/pulpax_db"

# JWT Security
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"

# API Configuration
PORT=6010
NODE_ENV=development
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef"
REDIS_PORT=6381

# CORS - Production: adjust origins
CORS_ORIGIN="https://localhost:6001,https://localhost:7001"

# Optional: Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# SMTP Configurations (Cloud Mailer - Leave empty to use console log simulation in development)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="smtp-username"
SMTP_PASS="smtp-password"
SMTP_FROM_NAME="Pulpax Support"
SMTP_FROM_EMAIL="support@pulpax.com"
