// This is your master database Prisma schema file.
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------
// 1. SYSTEM & TENANT CORE MODELS
// ----------------------------------------------------------------------

model Clinic {
  id        String   @id @default(uuid())
  name      String
  taxId     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // SaaS Fields
  status              String    @default("TRIAL") // TRIAL, ACTIVE, SUSPENDED, CANCELLED
  plan                String    @default("FREE") // FREE, BASIC, PRO, ENTERPRISE
  trialEndDate        DateTime? @map("trial_end_date")
  subscriptionEndDate DateTime? @map("subscription_end_date")
  smsQuota            Int       @default(0) @map("sms_quota")
  currentBalance      Decimal   @default(0.00) @map("current_balance")

  // Dynamic Routing Database connection string for Database-per-Tenant
  databaseUrl         String?   @map("database_url")

  // Sistem Yöneticisi: silinemez ama başka bir kullanıcıya devredilebilir tekil hesap.
  systemAdminUserId String? @map("system_admin_user_id")
  systemAdminUser   User?   @relation("ClinicSystemAdmin", fields: [systemAdminUserId], references: [id])

  // Relationships
  users             User[]
  userClinics       UserClinic[]

  @@map("clinics")
}

model User {
  id       String  @id @default(uuid())
  clinicId String? @map("clinic_id")
  clinic   Clinic? @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  firstName          String    @map("first_name")
  lastName           String    @map("last_name")
  email              String    @map("email_encrypted")
  emailHash          String    @unique @map("email_hash")
  password           String?   @map("password_hash") // null = davet gönderildi ama henüz kabul edilmedi (giriş yapılamaz)
  phone              String?
  nationalId         String?   @map("national_id")
  title              String?   @map("title")
  role               String // SAAS_SUPERADMIN, SAAS_BILLING, SAAS_SUPPORT, SUPERADMIN, ADMIN, DOCTOR, ASSISTANT, RECEPTION
  isActive           Boolean   @default(true) @map("is_active")
  deactivatedAt      DateTime? @map("deactivated_at")
  deactivationReason String?   @map("deactivation_reason")

  // Tenant DB'deki Employee.id'ye zayıf referans (farklı fiziksel DB, gerçek FK değil).
  // Personel (İK) kaydı olmadan da (örn. saf Admin hesabı) bir User var olabilir — bu yüzden opsiyonel.
  employeeId String? @unique @map("employee_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  userClinics         UserClinic[]
  systemAdminOfClinics Clinic[] @relation("ClinicSystemAdmin")

  @@map("users")
}

/// Kullanıcı-Klinik ilişki tablosu (Multi-Tenant)
model UserClinic {
  id       String @id @default(uuid())
  userId   String @map("user_id")
  clinicId String @map("clinic_id")

  role     String  @default("DOCTOR") // Bu kliniğe özel rol
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([userId, clinicId])
  @@index([userId])
  @@index([clinicId])
  @@map("user_clinics")
}

model ExchangeRate {
  id                String   @id @default(uuid())
  currencyCode      String   @map("currency_code")
  currencyName      String   @map("currency_name")
  buyingRate        Decimal  @map("buying_rate")
  sellingRate       Decimal  @map("selling_rate")
  rateDate          DateTime @db.Date @map("rate_date")
  isBusinessDay     Boolean  @default(true) @map("is_business_day")
  fetchedAt         DateTime @default(now()) @map("fetched_at")

  @@unique([currencyCode, rateDate])
  @@map("exchange_rates")
}

model MasterAuditLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  action    String
  target    String
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("master_audit_logs")
}

