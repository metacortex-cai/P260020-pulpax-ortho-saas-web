{
  "name": "pulpax-clinic-backend",
  "version": "1.1.6",
  "description": "Pulpax Clinic Management SaaS Backend",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "start": "nest start",
    "start:dev": "rimraf dist && xcopy /E /I /Y src\\prisma\\tenant-client dist\\src\\prisma\\tenant-client && nest start --watch",
    "start:dev:docker": "mkdir -p dist/src/prisma && cp -r src/prisma/tenant-client dist/src/prisma/tenant-client && nest start --watch",
    "start:debug": "rimraf dist && nest start --debug --watch",
    "start:prod": "node dist/main",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts",
    "db:seed:ortho": "ts-node scripts/seed-ortho-tariffs.ts",
    "db:rls": "ts-node prisma/apply-rls.ts",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.0.0",
    "prisma": "^5.22.0",
    "@sentry/node": "^10.62.0",
    "@sentry/profiling-node": "^10.62.0",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.77.0",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cookie-parser": "^1.4.6",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "tesseract.js": "^5.1.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "@types/bcrypt": "^5.0.0",
    "@types/cheerio": "^0.22.35",
    "@types/cookie-parser": "^1.4.6",
    "@types/cron": "^2.0.1",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.12",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^3.0.8",
    "@types/supertest": "^6.0.2",
    "@types/xml2js": "^0.4.14",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  }
}
