// ----------------------------------------------------------------------
// 7. EMPLOYEE CONTRACTS & PRIM RECORDS
// ----------------------------------------------------------------------

model EmployeeContract {
  id       String @id @default(uuid())
  clinicId String @map("clinic_id")

  employeeId String   @map("employee_id")
  employee   Employee @relation(fields: [employeeId], references: [id])

  version    Int       @default(1)
  type       String // MODEL_1, MODEL_2, MODEL_3, MODEL_4 (ADR-003 Faz 3 — 4 prim modeli)
  rate       Decimal   @default(0.00) // rateMode=BULK iken kullanılan toplu oran (%)
  conditions String?
  validFrom  DateTime  @map("valid_from")
  validUntil DateTime? @map("valid_until")

  fixedSalary Decimal @default(0.00) @map("fixed_salary")
  rateMode    String  @default("BULK") @map("rate_mode") // BULK, CATEGORY

  targetEnabled   Boolean  @default(false) @map("target_enabled")
  targetAmount    Decimal? @map("target_amount")
  targetCarryOver Boolean  @default(false) @map("target_carry_over")

  createdAt DateTime @default(now()) @map("created_at")

  primRecords   PrimRecord[]
  categoryRates EmployeeContractCategoryRate[]
  itemFees      EmployeeContractItemFee[]

  @@index([clinicId])
  @@map("employee_contracts")
}

// ADR-003 Faz 3: rateMode=CATEGORY iken kategori bazlı prim oranları (Model-1/2/3)
model EmployeeContractCategoryRate {
  id         String           @id @default(uuid())
  contractId String           @map("contract_id")
  contract   EmployeeContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  category String // MasterTreatment.category ile eşleşir
  rate     Decimal

  @@unique([contractId, category])
  @@map("employee_contract_category_rates")
}

// ADR-003 Faz 3: Model-4 için tedavi kalemi bazlı sabit ücret
model EmployeeContractItemFee {
  id         String           @id @default(uuid())
  contractId String           @map("contract_id")
  contract   EmployeeContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  masterTreatmentId String  @map("master_treatment_id")
  fixedFee          Decimal @map("fixed_fee")

  @@unique([contractId, masterTreatmentId])
  @@map("employee_contract_item_fees")
}

model PrimRecord {
  id       String @id @default(uuid())
  clinicId String @map("clinic_id")

  employeeId String   @map("employee_id")
  employee   Employee @relation(fields: [employeeId], references: [id])

  treatmentItemId String        @map("treatment_item_id")
  treatmentItem   TreatmentItem @relation(fields: [treatmentItemId], references: [id])

  contractId String           @map("contract_id")
  contract   EmployeeContract @relation(fields: [contractId], references: [id])

  amount                Decimal
  period                String   @default("") @map("period") // "YYYY-MM" — hedef sistemi mutabakatı için
  status                String   @default("CONFIRMED") @map("status") // PROVISIONAL, CONFIRMED, VOID
  paymentDistributionId String?  @map("payment_distribution_id")
  calculatedAt          DateTime @default(now()) @map("calculated_at")
  idempotencyKey        String   @unique @map("idempotency_key")

  @@index([clinicId])
  @@index([clinicId, employeeId, period])
  @@map("prim_records")
}

// ADR-003 Faz 3: hedef bazlı prim sistemi için aylık ciro/hedef takibi
model DoctorTargetLedger {
  id         String   @id @default(uuid())
  clinicId   String   @map("clinic_id")
  employeeId String   @map("employee_id")
  employee   Employee @relation(fields: [employeeId], references: [id])

  period          String    @map("period") // "YYYY-MM"
  targetAmount    Decimal   @map("target_amount")
  actualRevenue   Decimal   @default(0.00) @map("actual_revenue")
  achieved        Boolean   @default(false)
  carriedFromPrev Decimal   @default(0.00) @map("carried_from_prev")
  carriedToNext   Decimal   @default(0.00) @map("carried_to_next")
  reconciledAt    DateTime? @map("reconciled_at")

  @@unique([clinicId, employeeId, period])
  @@map("doctor_target_ledgers")
}

