// ----------------------------------------------------------------------
// 9. INVENTORY & WAREHOUSE
// ----------------------------------------------------------------------

model Warehouse {
  id       String @id @default(uuid())
  clinicId String @map("clinic_id")

  name        String
  description String?
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stocks        InventoryStock[]
  batches       InventoryBatch[]
  movementsTo   StockMovement[]  @relation("ToWarehouse")
  movementsFrom StockMovement[]  @relation("FromWarehouse")

  @@index([clinicId])
  @@map("warehouses")
}

model Supplier {
  id       String @id @default(uuid())
  clinicId String @map("clinic_id")

  name          String
  contactPerson String? @map("contact_person")
  email         String?
  phone         String?
  address       String?
  taxNumber     String? @map("tax_number")
  taxOffice     String? @map("tax_office")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  movements StockMovement[]

  @@index([clinicId])
  @@map("suppliers")
}

model InventoryItem {
  id       String @id @default(uuid())
  clinicId String @map("clinic_id")

  name          String
  sku           String? // Stock Keeping Unit
  barcode       String?
  category      String?
  unit          String  @default("ADET") // ADET, KG, LT, PAKET vb.
  criticalLevel Decimal @default(0) @map("critical_level")

  description String?
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stocks    InventoryStock[]
  batches   InventoryBatch[]
  movements StockMovement[]

  @@unique([clinicId, sku])
  @@index([clinicId, barcode])
  @@map("inventory_items")
}

model InventoryStock {
  id       String @id @default(uuid())
  clinicId String @map("clinic_id")

  itemId String        @map("item_id")
  item   InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  warehouseId String    @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  quantity Decimal @default(0)

  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([warehouseId, itemId])
  @@index([clinicId, itemId])
  @@map("inventory_stocks")
}

model InventoryBatch {
  id       String @id @default(uuid())
  clinicId String @map("clinic_id")

  itemId String        @map("item_id")
  item   InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  warehouseId String    @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  batchNumber String?   @map("batch_number")
  expiryDate  DateTime? @map("expiry_date")
  quantity    Decimal   @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clinicId, itemId])
  @@index([expiryDate])
  @@map("inventory_batches")
}

model StockMovement {
  id       String @id @default(uuid())
  clinicId String @map("clinic_id")

  itemId String        @map("item_id")
  item   InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  type     String // IN, OUT, TRANSFER, ADJUSTMENT
  quantity Decimal

  fromWarehouseId String?    @map("from_warehouse_id")
  fromWarehouse   Warehouse? @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])

  toWarehouseId String?    @map("to_warehouse_id")
  toWarehouse   Warehouse? @relation("ToWarehouse", fields: [toWarehouseId], references: [id])

  supplierId String?   @map("supplier_id")
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  batchNumber String?   @map("batch_number")
  expiryDate  DateTime? @map("expiry_date")

  reason String?
  note   String?

  userId String? @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([clinicId, itemId])
  @@index([createdAt])
  @@map("stock_movements")
}

model Medication {
  id               String   @id @default(uuid())
  barcode          String   @unique
  name             String
  activeSubstance  String?  @map("active_substance")
  manufacturer     String?
  prescriptionType String?  @map("prescription_type")
  sgkCovered       Boolean  @default(false) @map("sgk_covered")
  lastSyncedAt     DateTime @default(now()) @map("last_synced_at")

  @@index([name])
  @@index([activeSubstance])
  @@map("medications")
}

model ClinicIntegration {
  id              String    @id @default(uuid())
  clinicId        String    @map("clinic_id")
  integrationType String    @default("parasut") @map("integration_type")
  companyId       String?   @map("company_id")
  accessTokenEnc  String?   @map("access_token_enc")
  refreshTokenEnc String?   @map("refresh_token_enc")
  tokenExpiresAt  DateTime? @map("token_expires_at")
  status          String    @default("active")
  connectedAt     DateTime  @default(now()) @map("connected_at")
  lastRefreshAt   DateTime? @map("last_refresh_at")

  @@unique([clinicId, integrationType])
  @@map("clinic_integrations")
}

model ParasutSyncLog {
  id              String   @id @default(uuid())
  clinicId        String   @map("clinic_id")
  entityType      String   @map("entity_type")
  entityId        String   @map("entity_id")
  parasutEntityId String?  @map("parasut_entity_id")
  operation       String   @map("operation")
  status          String   @map("status")
  errorMessage    String?  @map("error_message")
  requestPayload  Json?    @map("request_payload")
  responsePayload Json?    @map("response_payload")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([clinicId])
  @@map("parasut_sync_logs")
}

model Notification {
  id        String   @id @default(uuid())
  clinicId  String   @map("clinic_id")
  userId    String?  @map("user_id")
  type      String
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([clinicId])
  @@index([userId])
  @@map("notifications")
}

model ExpenseCategory {
  id          String  @id @default(uuid())
  clinicId    String  @map("clinic_id")
  name        String
  description String?

  expenses Expense[]

  @@unique([clinicId, name])
  @@map("expense_categories")
}

model Expense {
  id       String @id @default(uuid())
  clinicId String @map("clinic_id")

  categoryId String          @map("category_id")
  category   ExpenseCategory @relation(fields: [categoryId], references: [id])

  amount      Decimal
  description String?
  expenseDate DateTime @default(now()) @map("expense_date")

  paymentMethod String @default("CASH") @map("payment_method") // CASH, CREDIT_CARD, TRANSFER

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clinicId, expenseDate])
  @@map("expenses")
}

// ----------------------------------------------------------------------
// 10. ORTHODONTICS (Pulpax Ortho)
// ----------------------------------------------------------------------
// Ortodonti vakası: bir hastanın tek bir ortodontik tedavi epizodu.
// Faturalama ayrı bir sistem DEĞİLDİR: her ücretli aksiyon (track başlatma,
// mini vida, aparey tamiri) mevcut TreatmentPlan/TreatmentItem/Tariff
// zincirine bağlanır. Ortodonti-özel modeller yalnızca klinik ilerlemeyi tutar.

model OrthoCase {
  id       String @id @default(uuid())
  clinicId String @map("clinic_id")

  patientId String  @map("patient_id")
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  doctorId String?   @map("doctor_id")
  doctor   Employee? @relation(fields: [doctorId], references: [id])

  startDate DateTime @default(now()) @map("start_date")
  // AKTIF | TAMAMLANDI | RETANSIYONDA | IPTAL
  status    String   @default("AKTIF")

  // Faz 01: başvuru şikayeti / beklenti notu
  complaint   String? @db.Text
  expectation String? @db.Text
  notes       String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  diagnoses         OrthoDiagnosis[]
  recordSets        OrthoRecordSet[]
  tracks            OrthoTreatmentTrack[]
  miniScrews        OrthoMiniScrewRecord[]
  growthAssessments OrthoGrowthAssessment[]
  retentionPlans    OrthoRetentionPlan[]

  @@index([clinicId, patientId])
  @@index([patientId])
  @@map("ortho_cases")
}

// Faz 02: klinik bulgular + model analizi. Zaman içinde yeniden değerlendirme
// yapılabildiği için vaka başına birden fazla kayıt tutulur (one-to-many).
model OrthoDiagnosis {
  id     String    @id @default(uuid())
  caseId String    @map("case_id")
  case   OrthoCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  examDate DateTime @default(now()) @map("exam_date")
  doctorId String?  @map("doctor_id")

  // İskeletsel / oklüzal bulgular
  skeletalClass    String?  @map("skeletal_class") // SINIF_I | SINIF_II | SINIF_III
  profileType      String?  @map("profile_type") // DUZ | KONVEKS | KONKAV
  overjet          Decimal? // mm
  overbite         Decimal? // % örtme
  crowding         String? // HAFIF | ORTA | SIDDETLI
  openBite         String?  @map("open_bite") // bölge/mm notu
  deepBite         String?  @map("deep_bite")
  crossbite        String? // bölge, mm
  midlineDeviation String?  @map("midline_deviation") // mm + yön
  tmjAssessment    String?  @map("tmj_assessment") // ağrı/klik/kısıtlılık

  // Sefalometrik açı ölçümleri (SNA, SNB, ANB, vb.) — serbest anahtar/değer
  cephalometricValues Json? @map("cephalometric_values")

  // Model analizi
  boltonAnalysis    String? @map("bolton_analysis") @db.Text
  haysNanceAnalysis String? @map("hays_nance_analysis") @db.Text

  // ICON malokluzyon skoru (mevcut UI'daki değerlendirme burada persist edilir)
  iconScore   Int?  @map("icon_score")
  iconDetails Json? @map("icon_details") // bölüm bazlı seçimler

  notes String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([caseId])
  @@map("ortho_diagnoses")
}

// Faz 02 & 07: foto/röntgen/tarama kayıtları — faz etiketiyle arşivlenir,
// dosya saklama düzeni PatientDocument ile aynıdır (fileUrl + fileType).
model OrthoRecordSet {
  id     String    @id @default(uuid())
  caseId String    @map("case_id")
  case   OrthoCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // FOTO | OPG | SEFALOMETRIK | EL_BILEK | CBCT | STL
  recordType String @map("record_type")
  // FAZ01..FAZ08 — öncesi/sonrası eşleştirmesi bu etiketle yapılır
  phase      String

  name        String
  fileUrl     String  @map("file_url")
  fileType    String? @map("file_type") // IMAGE, PDF, STL...
  fileSize    Int?    @map("file_size")
  description String?

  takenAt    DateTime @default(now()) @map("taken_at")
  uploadedBy String?  @map("uploaded_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([caseId, phase])
  @@map("ortho_record_sets")
}

// Faz 04-08: vaka içinde yürüyen tek bir tedavi tipi. Yeni tedavi tipi
// eklemek şema değişikliği değil, yeni bir trackType değeri gerektirir.
model OrthoTreatmentTrack {
  id     String    @id @default(uuid())
  caseId String    @map("case_id")
  case   OrthoCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // SABIT | ALIGNER | RPE | HEADGEAR | HABIT | SPACE_MAINTAINER |
  // MYOFUNCTIONAL | ORTHO_RESTORATIVE | KISA_SURELI
  trackType String @map("track_type")

  // Fiyat/kademe bilgisini taşıyan tedavi kalemi (ör. "Sabit Tedavi - 3. Seviye"
  // tarifesine bağlı TreatmentItem). Fatura bu kalem üzerinden yürür.
  treatmentItemId String?        @unique @map("treatment_item_id")
  treatmentItem   TreatmentItem? @relation(fields: [treatmentItemId], references: [id])

  // AKTIF | BITIRME | TAMAMLANDI | IPTAL
  status    String    @default("AKTIF")
  startDate DateTime  @default(now()) @map("start_date")
  endDate   DateTime? @map("end_date")

  // Aparey yerleştirme kaydı (Faz 04): marka/malzeme, ilk tel/set bilgisi
  applianceInfo String? @map("appliance_info") @db.Text
  notes         String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  adjustmentVisits OrthoAdjustmentVisit[]
  activationLogs   OrthoActivationLog[]
  alignerSets      OrthoAlignerSet[]

  @@index([caseId])
  @@map("ortho_treatment_tracks")
}

// Faz 05: randevuya bağlı ilerleme — sabit/aligner track'lerinin ziyaret kaydı.
model OrthoAdjustmentVisit {
  id      String              @id @default(uuid())
  trackId String              @map("track_id")
  track   OrthoTreatmentTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  appointmentId String?      @map("appointment_id")
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  visitDate DateTime @default(now()) @map("visit_date")
  doctorId  String?  @map("doctor_id")

  wireSize       String? @map("wire_size") // örn. 0.014 NiTi
  elasticType    String? @map("elastic_type") // Class II / III / çapraz + kullanım süresi
  iprDone        Boolean @default(false) @map("ipr_done")
  iprNote        String? @map("ipr_note") // bölge, mm
  complianceNote String? @map("compliance_note") // hasta uyumu
  nextVisitWeeks Int?    @map("next_visit_weeks")
  isEmergency    Boolean @default(false) @map("is_emergency") // kırık braket, batan tel vb.
  note           String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([trackId, visitDate])
  @@map("ortho_adjustment_visits")
}

// Faz 05: randevu dışı ilerleme — RME vida turu, headgear kullanım süresi,
// miyofonksiyonel egzersiz tekrarı. Zaman çizelgesinde ayrı satır tipi olur.
model OrthoActivationLog {
  id      String              @id @default(uuid())
  trackId String              @map("track_id")
  track   OrthoTreatmentTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  date DateTime @default(now())

  // VIDA_TURU | KULLANIM_SURESI | EGZERSIZ
  logType String   @map("log_type")
  value   Decimal? // tur sayısı, saat, tekrar
  unit    String? // TUR | SAAT | TEKRAR
  note    String?  @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([trackId, date])
  @@map("ortho_activation_logs")
}

// Faz 05 (aligner): set teslimi, refinement ve uyum takibi.
model OrthoAlignerSet {
  id      String              @id @default(uuid())
  trackId String              @map("track_id")
  track   OrthoTreatmentTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  setNo        Int      @map("set_no")
  deliveryDate DateTime @default(now()) @map("delivery_date")
  isRefinement Boolean  @default(false) @map("is_refinement")

  wearComplianceNote String? @map("wear_compliance_note") // wear-time / tracking notu

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([trackId, setNo])
  @@map("ortho_aligner_sets")
}

// Faz 05: mini vida (TAD) kaydı — vida başına faturalanır: her kayıt
// "Mini Vida (Adet)" tarifesine bağlı bir TreatmentItem'a karşılık gelir.
model OrthoMiniScrewRecord {
  id     String    @id @default(uuid())
  caseId String    @map("case_id")
  case   OrthoCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  treatmentItemId String?        @unique @map("treatment_item_id")
  treatmentItem   TreatmentItem? @relation(fields: [treatmentItemId], references: [id])

  region        String // örn. "Üst sağ bukkal 15-16 arası"
  placementDate DateTime  @default(now()) @map("placement_date")
  purpose       String? // ankraj amacı
  removalDate   DateTime? @map("removal_date")

  followUpDates DateTime[] @map("follow_up_dates")
  // AKTIF | CIKARILDI | KAYBEDILDI
  status        String     @default("AKTIF")
  note          String?    @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([caseId])
  @@map("ortho_mini_screw_records")
}

// Özel süreç: büyüme takibi — el-bilek röntgeniyle iskelet yaşı izleme.
model OrthoGrowthAssessment {
  id     String    @id @default(uuid())
  caseId String    @map("case_id")
  case   OrthoCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  xrayDate    DateTime @default(now()) @map("xray_date") // el-bilek röntgen tarihi
  skeletalAge String?  @map("skeletal_age")
  // Büyüme atılımı fazı: ATILIM_ONCESI | ATILIMDA | ATILIM_SONRASI
  growthPhase String?  @map("growth_phase")
  note        String?  @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([caseId])
  @@map("ortho_growth_assessments")
}

// Faz 08: retansiyon — kapanan dosya değil, kendi takvimi olan kalıcı faz.
model OrthoRetentionPlan {
  id     String    @id @default(uuid())
  caseId String    @map("case_id")
  case   OrthoCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // SABIT_LINGUAL | HAWLEY | ESSIX
  retainerType String @map("retainer_type")
  // TEK | CIFT çene
  archCoverage String @map("arch_coverage")

  deliveryDate     DateTime? @map("delivery_date")
  // Kontrol takvimi: [{label: "1. Ay", dueDate: "..."}, ...]
  followUpSchedule Json?     @map("follow_up_schedule")
  usageInstruction String?   @map("usage_instruction") // ilk 3-6 ay tam gün → gece

  // AKTIF | GEVSEMIS | KIRIK_KAYIP | YENILENDI | TAMAMLANDI
  status String  @default("AKTIF")
  note   String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([caseId])
  @@map("ortho_retention_plans")
}
