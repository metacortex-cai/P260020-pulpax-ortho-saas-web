{
  "name": "pulpax-clinic-frontend",
  "version": "1.1.6",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack --port 7101 --experimental-https --experimental-https-key ../certs/localhost.key --experimental-https-cert ../certs/localhost.crt",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test:e2e": "npm run test:e2e:docker",
    "test:functional": "npm run test:e2e:docker",
    "test:regression": "npm run test:regression:docker",
    "test:e2e:local": "playwright test",
    "test:functional:local": "playwright test",
    "test:regression:local": "playwright test --grep @regression",
    "test:e2e:docker": "docker run --rm -e CI=1 -v ${PWD}:/e2e -w /e2e mcr.microsoft.com/playwright:v1.46.1-jammy bash -lc \"npm install --legacy-peer-deps && npx playwright test\"",
    "test:functional:docker": "docker run --rm -e CI=1 -v ${PWD}:/e2e -w /e2e mcr.microsoft.com/playwright:v1.46.1-jammy bash -lc \"npm install --legacy-peer-deps && npx playwright test\"",
    "test:regression:docker": "docker run --rm -e CI=1 -v ${PWD}:/e2e -w /e2e mcr.microsoft.com/playwright:v1.46.1-jammy bash -lc \"npm install --legacy-peer-deps && npx playwright test --grep @regression\""
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.6",
    "@hookform/resolvers": "^5.4.0",
    "@sentry/nextjs": "^10.62.0",
    "axios": "^1.6.0",
    "date-fns": "^4.2.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.300.0",
    "next": "^16.2.7",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.77.0",
    "react-is": "^18.3.1",
    "exceljs": "^4.4.0",
    "recharts": "^3.8.1",
    "zod": "^4.4.3",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^9.15.0",
    "eslint-config-next": "^16.2.7",
    "eslint-config-prettier": "^9.1.0",
    "postcss": "^8.5.10",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
