# Playwright E2E Test Ortam Değişkenleri
# Bu dosyayı .env.test olarak kaydedin veya sisteminizde ortam değişkeni olarak tanımlayın.

# API URL (backend-clinic)
NEXT_PUBLIC_API_URL=https://localhost:7010/api/v1

# E2E Test Kullanıcısı (seed.ts'de tanımlı doctor@pulpax.test)
E2E_TEST_EMAIL=doctor@pulpax.test
# SEED_ADMIN_PASSWORD değeri ile aynı olmalı
E2E_TEST_PASSWORD=

# Test hastası (gerçek bir hasta ID'si girilmeli)
E2E_TEST_PATIENT_ID=
